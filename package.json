{
  "name": "obsidian-cooklang",
  "version": "1.0.1",
  "description": "Render Cooklang recipes inside Obsidian.",
  "keywords": [
    "cooking",
    "cooklang",
    "obsidian",
    "obsidian-plugin",
    "recipe"
  ],
  "bugs": {
    "url": "https://github.com/tomvoet/obsidian-cooklang/issues"
  },
  "license": "MIT",
  "author": "Tom Voet",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tomvoet/obsidian-cooklang.git"
  },
  "main": "main.js",
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "svelte-check && vite build",
    "check": "svelte-check",
    "lint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "dependencies": {
    "scule": "^1.3.0"
  },
  "devDependencies": {
    "@cooklang/cooklang": "^0.18.7",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.1",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^25.9.3",
    "builtin-modules": "^5.2.0",
    "date-fns": "^4.4.0",
    "obsidian": "^1.13.1",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "svelte": "^5.56.3",
    "svelte-check": "^4.6.0",
    "tailwindcss": "^4.3.1",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  },
  "packageManager": "pnpm@9.15.3"
}
