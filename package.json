{
    "name": "obsidian-cooklang",
    "version": "1.0.0",
    "description": "Render Cooklang recipes inside Obsidian.",
    "main": "main.js",
    "license": "MIT",
    "author": "Tom Voet",
    "keywords": [
        "obsidian",
        "obsidian-plugin",
        "cooklang",
        "recipe",
        "cooking"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/tomvoet/obsidian-cooklang.git"
    },
    "bugs": {
        "url": "https://github.com/tomvoet/obsidian-cooklang/issues"
    },
    "packageManager": "pnpm@9.15.3",
    "scripts": {
        "dev": "vite build --watch --mode development",
        "build": "svelte-check && vite build",
        "check": "svelte-check",
        "lint": "eslint .",
        "version": "node version-bump.mjs && git add manifest.json versions.json"
    },
    "devDependencies": {
        "@cooklang/cooklang": "^0.18.7",
        "@cooklang/cooklang-ts": "^1.2.8",
        "@eslint/js": "^10.0.1",
        "@stylistic/eslint-plugin": "^5.10.0",
        "@sveltejs/vite-plugin-svelte": "^7.1.2",
        "@tsconfig/svelte": "^5.0.8",
        "@types/node": "^25.9.3",
        "builtin-modules": "^5.2.0",
        "eslint": "^10.5.0",
        "eslint-plugin-svelte": "^3.19.0",
        "globals": "^17.6.0",
        "obsidian": "^1.13.1",
        "svelte": "^5.56.3",
        "svelte-check": "^4.6.0",
        "tslib": "^2.8.1",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.61.0",
        "vite": "^8.0.16"
    },
    "dependencies": {
        "scule": "^1.3.0"
    }
}
